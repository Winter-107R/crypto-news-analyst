{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "CryptoAnalystApplication",
      "request": "launch",
      "mainClass": "com.winter107r.cryptoanalyst.CryptoAnalystApplication",
      "projectName": "crypto-news-analyst"
    },
    {
      "type": "java",
      "name": "CryptoAnalystApplication (OpenAI)",
      "request": "launch",
      "mainClass": "com.winter107r.cryptoanalyst.CryptoAnalystApplication",
      "projectName": "crypto-news-analyst",
      "args": "--spring.profiles.active=openai",
      "env": {
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}"
      }
    }
  ]
}
